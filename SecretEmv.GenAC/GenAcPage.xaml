<Page
    x:Class="SecretEmv.GenAC.AcGenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="16">
        <StackPanel Spacing="12" MaxWidth="800">

            <!-- Block cipher + derivation method -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Block Cipher" FontWeight="Bold"/>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <RadioButton x:Name="Rb3Des"
                                 Content="3DES"
                                 IsChecked="True"
                                 Checked="BlockCipher_Checked"/>
                    <RadioButton x:Name="RbAes"
                                 Content="AES"
                                 Checked="BlockCipher_Checked"/>
                </StackPanel>

                <TextBlock Text="Derivation Method" FontWeight="Bold" Margin="0,8,0,0"/>

                <!-- 3DES methods -->
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <RadioButton x:Name="Rb3DesOptionA"
                                 Content="Option A — PAN ≤ 16 digits"
                                 IsEnabled="False"/>
                    <RadioButton x:Name="Rb3DesOptionB"
                                 Content="Option B — PAN > 16 digits"
                                 IsEnabled="False"/>
                </StackPanel>

                <!-- AES method -->
                <RadioButton x:Name="RbAesOption3"
                             Content="Option 3 — AES-CMAC"
                             IsEnabled="False"
                             Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Section 1: Card Master Key -->
            <Expander Header="Card Master Key" IsExpanded="True">
                <StackPanel Spacing="8">
                    <TextBlock Text="IMK-AC (hex)" />
                    <TextBox x:Name="TxtImkAc" 
                             MaxWidth="600" 
                             HorizontalAlignment="Stretch"
                             TextChanged="ImkAc_TextChanged"
                             LostFocus="HexInput_LostFocus" />

                    <TextBlock x:Name="TxtImkKcv" 
                               Text="" 
                               FontSize="12" 
                               Foreground="Gray" 
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Width="200">
                            <TextBlock Text="PAN (digits)" />
                            <TextBox x:Name="TxtPan" 
                                     TextChanged="Pan_TextChanged"
                                     LostFocus="HexInput_LostFocus"/>
                        </StackPanel>

                        <StackPanel Width="80">
                            <TextBlock Text="PSN (2 digits)" />
                            <TextBox x:Name="TxtPsn" 
                                     LostFocus="HexInput_LostFocus"/>
                        </StackPanel>

                        <StackPanel Width="200" Visibility="Collapsed" x:Name="AesKeyLengthPanel">
                            <TextBlock Text="AES Key Length" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton x:Name="RbAes128"
                                             Content="128-bit"
                                             IsChecked="True"
                                             Checked="AesKeyLength_Checked"/>
                                <RadioButton x:Name="RbAes192"
                                             Content="192-bit"
                                             Checked="AesKeyLength_Checked"/>
                                <RadioButton x:Name="RbAes256"
                                             Content="256-bit"
                                             Checked="AesKeyLength_Checked"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Generate Card Master Key"
                            Click="GenerateCardMasterKey_Click"
                            Margin="0,8,0,0"/>

                    <TextBlock Text="Card Master Key (hex)" />
                    <TextBox x:Name="TxtCardMasterKey" 
                             IsReadOnly="True" 
                             MaxWidth="600" 
                             HorizontalAlignment="Stretch" 
                             LostFocus="HexInput_LostFocus"/>

                </StackPanel>
            </Expander>

            <!-- Section 2: Session Key -->
            <Expander Header="Session Key (SK_AC)" IsExpanded="True">
                <StackPanel Spacing="8">
                    <StackPanel Width="120">
                        <TextBlock Text="ATC (hex)" />
                        <TextBox x:Name="TxtAtc"
                                 LostFocus="HexInput_LostFocus"/>
                    </StackPanel>

                    <Button Content="Generate Session Key"
                            Click="GenerateSessionKey_Click"
                            Margin="0,8,0,0"/>

                    <TextBlock Text="Session Key (hex)" />
                    <TextBox x:Name="TxtSessionKey" 
                             IsReadOnly="True" 
                             MaxWidth="600" 
                             HorizontalAlignment="Stretch"
                             LostFocus="HexInput_LostFocus"/>

                </StackPanel>
            </Expander>

            <!-- Section 3: ARQC / ARPC -->
            <Expander Header="ARQC and ARPC" IsExpanded="True">
                <StackPanel Spacing="8">
                    <!-- DOL Input -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="DOL (hex)" />
                        <TextBox x:Name="TxtDol" 
                                   MaxWidth="600" 
                                   HorizontalAlignment="Stretch"
                                   TextChanged="TxtDol_TextChanged" />
                    </StackPanel>
                    <!-- Tag Values Input -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Tag Values (hex)" />
                        <TextBox x:Name="TxtTagValues" 
                                 MaxWidth="600" 
                                 HorizontalAlignment="Stretch"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 LostFocus="HexInput_LostFocus" />
                    </StackPanel>

                    <!-- ARC/CSU Input -->
                    <StackPanel Spacing="8">
                        <TextBlock>
                            <Run Text="ARC/CSU (hex)" FontWeight="Bold"/>
                            <LineBreak/>
                            <Run Text="2 bytes for ARC (e.g. 3030) or 4 bytes for CSU (e.g. 00820000)" 
                                 FontSize="10" 
                                 Foreground="Gray"/>
                        </TextBlock>
                        <TextBox x:Name="TxtArc" 
                                 Text="00820000" 
                                 MaxWidth="600" 
                                 HorizontalAlignment="Stretch"
                                 PlaceholderText="Enter 2-byte ARC or 4-byte CSU"
                                 LostFocus="HexInput_LostFocus"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Button Content="Generate ARQC"
                                Click="GenerateArqc_Click"/>
                        <Button Content="Generate ARPC"
                                Click="GenerateArpc_Click"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="ARQC (hex)" />
                        <TextBox x:Name="TxtArqc" IsReadOnly="True" MaxWidth="600" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="ARPC (hex)" />
                        <TextBox x:Name="TxtArpc" IsReadOnly="True" MaxWidth="600" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Intermediate steps log -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Intermediate Steps" FontWeight="Bold"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200" MaxWidth="600" HorizontalAlignment="Stretch">
                            <TextBox x:Name="TxtLog"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"/>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Close Button -->
            <Button Content="Close" 
                    HorizontalAlignment="Left" 
                    Margin="0,12,0,0"
                    MinWidth="120"
                    Click="Close_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>
